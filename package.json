{
  "name": "trading212-sdk",
  "version": "1.0.1",
  "description": "Trading 212 JavaScript/TypeScript client library for the Trading 212 Public API",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "trading-212",
    "api",
    "client",
    "typescript",
    "trading",
    "stocks",
    "etf",
    "investments"
  ],
  "author": "Samuel Jochem",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "axios-mock-adapter": "^2.1.0",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samueljochem/trading212-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/samueljochem/trading212-sdk/issues"
  },
  "homepage": "https://github.com/samueljochem/trading212-sdk"
}
