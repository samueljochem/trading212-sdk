# Trading 212 API Credentials
# Get these from the Trading 212 app: Settings → API

# Your API Key
TRADING212_API_KEY=your-api-key-here

# Your API Secret
TRADING212_API_SECRET=your-api-secret-here

# API Environment: 'demo' for paper trading or 'live' for real money
# Default: demo
TRADING212_ENV=demo
